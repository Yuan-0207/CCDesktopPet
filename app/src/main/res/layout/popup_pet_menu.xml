<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="154dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_pet_menu_card"
    android:orientation="vertical"
    android:paddingStart="7dp"
    android:paddingTop="7dp"
    android:paddingEnd="7dp"
    android:paddingBottom="7dp">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/petMenuBtnAction1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_pet_menu_btn_primary"
        android:minHeight="30dp"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/pet_interaction_hello"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="#4A3D2E"
        android:textSize="12sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/petMenuBtnAction2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_pet_menu_btn_primary"
        android:minHeight="30dp"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/pet_interaction_pat"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="#4A3D2E"
        android:textSize="12sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/petMenuBtnAction3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_pet_menu_btn_primary"
        android:minHeight="30dp"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/pet_interaction_cheer"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="#4A3D2E"
        android:textSize="12sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/petMenuBtnIdle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_pet_menu_btn_secondary"
        android:minHeight="30dp"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/pet_menu_back_idle"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="#4A3D2E"
        android:textSize="12sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/petMenuBtnHide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pet_menu_btn_dismiss"
        android:minHeight="30dp"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="@string/pet_menu_hide"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="#6B4038"
        android:textSize="12sp" />
</LinearLayout>
