<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_soft">

    <LinearLayout
        android:id="@+id/nameSettingPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_settings_panel"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_pet_name_page_title"
            android:textColor="@color/brand_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_pet_name_hint"
            android:textColor="@color/brand_text_secondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/inputPetName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_settings_item_3d"
            android:hint="@string/settings_pet_name_input_hint"
            android:inputType="textPersonName"
            android:maxLength="12"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/brand_text_primary"
            android:textColorHint="@color/brand_text_hint"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSavePetName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_action_button"
            android:text="@string/settings_pet_name_save"
            android:textAllCaps="false"
            android:textColor="@color/brand_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
