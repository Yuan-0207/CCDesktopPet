<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_soft">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_settings_card_clean"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_game_title"
                android:textColor="@color/brand_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_settings_row_clean"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="@string/login_local_tag"
                android:textColor="@color/brand_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/login_local_hint"
                android:textColor="@color/brand_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_section"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_section_account_id"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLocalUserId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_row_clean"
                    android:padding="12dp"
                    android:textColor="@color/brand_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/login_local_user_id_tip"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_settings_section"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_section_profile"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etLocalNickname"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_row_clean"
                    android:gravity="center_vertical"
                    android:hint="@string/login_local_nickname_hint"
                    android:inputType="textPersonName"
                    android:maxLength="20"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/brand_text_primary"
                    android:textColorHint="@color/brand_text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvNicknameCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:text="@string/login_nickname_counter_initial"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_settings_section"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_section_notice"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_row_clean"
                    android:lineSpacingExtra="2dp"
                    android:padding="10dp"
                    android:text="@string/login_local_notice_body"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_settings_section"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_section_security"
                    android:textColor="@color/brand_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPhoneBindStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_row_clean"
                    android:padding="10dp"
                    android:textColor="@color/brand_text_primary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBindPhone"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_settings_row_clean"
                        android:text="@string/login_action_bind_phone"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_text_primary"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnPhonePasswordLogin"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_settings_row_clean"
                        android:text="@string/login_action_phone_login"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvLoginStatusHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_settings_row_clean"
                android:padding="10dp"
                android:textColor="@color/brand_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnLoginConfirmLocal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_settings_row_clean"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/login_local_confirm"
                android:textAllCaps="false"
                android:textColor="@color/brand_text_primary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLoginBack"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_row_clean"
                android:text="@string/login_back"
                android:textAllCaps="false"
                android:textColor="@color/brand_text_primary"
                android:textSize="20sp" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/loginLoadingMask"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_settings_card_clean"
            android:orientation="vertical"
            android:padding="16dp">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/login_loading"
                android:textColor="@color/brand_text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
