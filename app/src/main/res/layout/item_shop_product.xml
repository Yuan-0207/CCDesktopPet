<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_pet_card"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvShopItemTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_item"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp"
        android:textColor="@color/brand_text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvShopItemTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/brand_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/viewShopModelPreview"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_pet_preview_sakura"
        android:clipToOutline="true"
        android:foregroundGravity="center">

        <ImageView
            android:id="@+id/ivShopModelPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="4dp"
            android:layout_gravity="center"
            android:contentDescription="@string/shop_model_preview_placeholder"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvShopModelPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.85"
            android:text=""
            android:textColor="@color/brand_text_primary"
            android:textSize="12sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShopItemPreview"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_action_button"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="42dp"
            android:text="@string/shop_preview_open"
            android:textAllCaps="false"
            android:textColor="@color/brand_text_primary"
            android:textSize="14sp"
            app:backgroundTint="@null"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShopItemAction"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_button"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="42dp"
            android:textAllCaps="false"
            android:textColor="@color/brand_text_primary"
            android:textSize="14sp"
            app:backgroundTint="@null"
            app:cornerRadius="14dp" />
    </LinearLayout>

</LinearLayout>

