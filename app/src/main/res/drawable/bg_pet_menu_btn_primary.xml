<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:angle="270"
                android:endColor="#E8C9A0"
                android:startColor="#F2D4B0" />
            <stroke
                android:width="1dp"
                android:color="#C9A574" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:angle="270"
                android:endColor="#F5DEBD"
                android:startColor="#FFF3E0" />
            <stroke
                android:width="1dp"
                android:color="#D4B896" />
        </shape>
    </item>
</selector>
