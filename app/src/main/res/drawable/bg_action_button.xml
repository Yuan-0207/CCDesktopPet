<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item android:top="1dp">
                <shape>
                    <corners android:radius="16dp" />
                    <solid android:color="#5FA88663" />
                </shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <corners android:radius="16dp" />
                    <gradient
                        android:angle="270"
                        android:endColor="#F6DFC5"
                        android:startColor="#FFF7EC" />
                    <stroke
                        android:width="1dp"
                        android:color="#DFC2A6" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp">
                <shape>
                    <corners android:radius="16dp" />
                    <solid android:color="#5FA88663" />
                </shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <corners android:radius="16dp" />
                    <gradient
                        android:angle="270"
                        android:endColor="#F6DFC5"
                        android:startColor="#FFF7EC" />
                    <stroke
                        android:width="1dp"
                        android:color="#DFC2A6" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:top="3dp">
                <shape>
                    <corners android:radius="16dp" />
                    <solid android:color="#66AA8D71" />
                </shape>
            </item>
            <item android:bottom="3dp">
                <shape>
                    <corners android:radius="16dp" />
                    <gradient
                        android:angle="270"
                        android:endColor="#F9E7CF"
                        android:startColor="#FFFDF8" />
                    <stroke
                        android:width="1dp"
                        android:color="#E3CBB2" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
