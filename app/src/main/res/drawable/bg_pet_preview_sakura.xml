<?xml version="1.0" encoding="utf-8"?>
<!-- 立体圆框 + 樱花林配色（粉天 / 樱花带 / 浅绿地面），与早期渐变一致 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外缘：自上而下樱花林大氛围 -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:centerColor="#FFB7D5"
                android:endColor="#8DA87A"
                android:startColor="#FFF0F6"
                android:type="linear" />
        </shape>
    </item>
    <!-- 斜面：偏粉的倒角高光 -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:centerColor="#FFC8DC"
                android:endColor="#C89BB5"
                android:startColor="#FFFBFC"
                android:type="linear" />
        </shape>
    </item>
    <!-- 内凹展示面：樱花林主渐变（模型透明区域透出） -->
    <item
        android:bottom="10dp"
        android:left="10dp"
        android:right="10dp"
        android:top="10dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:centerColor="#FFB7D5"
                android:endColor="#9DB88E"
                android:startColor="#FFF5FA"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#E8A4BE" />
        </shape>
    </item>
</layer-list>
