<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="1dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#5FA88663" />
        </shape>
    </item>
    <item android:bottom="1dp">
        <shape>
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:endColor="#F6DFC5"
                android:startColor="#FFF7EC" />
            <stroke
                android:width="1dp"
                android:color="#DFC2A6" />
        </shape>
    </item>
</layer-list>
