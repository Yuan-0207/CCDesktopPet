<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp">
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="@color/brand_item_shadow" />
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape>
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:endColor="@color/brand_item_bottom"
                android:startColor="@color/brand_item_top" />
            <stroke
                android:width="1dp"
                android:color="@color/brand_item_stroke" />
        </shape>
    </item>
</layer-list>
